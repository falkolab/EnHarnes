{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) .claude/hooks/validate-bash.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) .claude/hooks/prompt-validator.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) .claude/hooks/post-response-sync.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "$(command -v python3 || command -v python) .claude/hooks/log-agent-usage.py"
          }
        ]
      }
    ]
  }
}
